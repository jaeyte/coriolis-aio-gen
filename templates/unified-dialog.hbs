<form class="coriolis-aio-gen-dialog">
  {{!-- Decorative header --}}
  <div class="coriolis-dialog-header">
    <div class="coriolis-star-row">
      <span class="coriolis-star"></span>
      <span class="coriolis-star"></span>
      <span class="coriolis-star"></span>
    </div>
    <p class="coriolis-dialog-subtitle">The Icons watch over your creation...</p>
  </div>

  {{!-- Hidden input to track active generator type --}}
  <input type="hidden" name="generatorType" value="{{initialTab}}" />

  {{!-- Generator type tabs --}}
  <div class="coriolis-gen-tabs">
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'character')}}active{{/if}}" data-tab="character">
      <i class="fas fa-dice-d20"></i> {{localize "CORIOLIS_AIO.Tab.Character"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'encounter')}}active{{/if}}" data-tab="encounter">
      <i class="fas fa-skull-crossbones"></i> {{localize "CORIOLIS_AIO.Tab.Encounter"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'ship')}}active{{/if}}" data-tab="ship">
      <i class="fas fa-rocket"></i> {{localize "CORIOLIS_AIO.Tab.Ship"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'shipEncounter')}}active{{/if}}" data-tab="shipEncounter">
      <i class="fas fa-crosshairs"></i> {{localize "CORIOLIS_AIO.Tab.ShipEncounter"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'party')}}active{{/if}}" data-tab="party">
      <i class="fas fa-users"></i> {{localize "CORIOLIS_AIO.Tab.Party"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'npc')}}active{{/if}}" data-tab="npc">
      <i class="fas fa-user-secret"></i> {{localize "CORIOLIS_AIO.Tab.NPC"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'mission')}}active{{/if}}" data-tab="mission">
      <i class="fas fa-scroll"></i> {{localize "CORIOLIS_AIO.Tab.Mission"}}
    </button>
    <button type="button" class="coriolis-gen-tab {{#if (eq initialTab 'aiNpc')}}active{{/if}}" data-tab="aiNpc">
      <i class="fas fa-brain"></i> {{localize "CORIOLIS_AIO.Tab.AINPC"}}
    </button>
  </div>

  {{!-- ═══════════════════════════════════════════════
       CHARACTER PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'character')}}hidden{{/unless}}" data-panel="character">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-id-card"></i> Identity</legend>

      <div class="form-group">
        <label for="aio-actor-type">{{localize "CORIOLIS_AIO.Dialog.ActorType"}}</label>
        <select id="aio-actor-type" name="actorType">
          <option value="character">{{localize "CORIOLIS_AIO.Dialog.Character"}}</option>
          <option value="npc">{{localize "CORIOLIS_AIO.Dialog.NPC"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label for="aio-name">{{localize "CORIOLIS_AIO.Dialog.Name"}}</label>
        <input type="text" id="aio-name" name="charName" placeholder="{{localize "CORIOLIS_AIO.Dialog.NamePlaceholder"}}" />
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-dice-d20"></i> Concept</legend>

      <div class="form-group">
        <label for="aio-concept">{{localize "CORIOLIS_AIO.Dialog.Concept"}}</label>
        <select id="aio-concept" name="conceptKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each concepts}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="aio-subconcept">{{localize "CORIOLIS_AIO.Dialog.SubConcept"}}</label>
        <select id="aio-subconcept" name="subConceptKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label for="aio-group-concept">{{localize "CORIOLIS_AIO.Dialog.GroupConcept"}}</label>
        <select id="aio-group-concept" name="groupConceptKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each groupConcepts}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-star-and-crescent"></i> Background</legend>

      <div class="form-group">
        <label for="aio-upbringing">{{localize "CORIOLIS_AIO.Dialog.Upbringing"}}</label>
        <select id="aio-upbringing" name="upbringingKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each upbringings}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="aio-origin">{{localize "CORIOLIS_AIO.Dialog.Origin"}}</label>
        <select id="aio-origin" name="originKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each origins}}
          <option value="{{this.key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="aio-icon">{{localize "CORIOLIS_AIO.Dialog.Icon"}}</label>
        <select id="aio-icon" name="iconKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each icons}}
          <option value="{{this.key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       ENCOUNTER PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'encounter')}}hidden{{/unless}}" data-panel="encounter">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-skull-crossbones"></i> Encounter</legend>

      <div class="form-group">
        <label for="aio-encounter-template">{{localize "CORIOLIS_AIO.Encounter.Template"}}</label>
        <select id="aio-encounter-template" name="templateKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each encounterTemplates}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
        <p class="hint" id="aio-encounter-desc"></p>
      </div>

      <div class="form-group">
        <label for="aio-difficulty">{{localize "CORIOLIS_AIO.Encounter.Difficulty"}}</label>
        <select id="aio-difficulty" name="difficulty">
          {{#each difficulties}}
          <option value="{{@key}}" {{#if this.default}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-users"></i> Party</legend>

      <div class="form-row">
        <div class="form-group">
          <label for="aio-party-size">{{localize "CORIOLIS_AIO.Encounter.PartySize"}}</label>
          <input type="number" id="aio-party-size" name="partySize" value="4" min="1" max="10" />
        </div>

        <div class="form-group">
          <label for="aio-party-xp">{{localize "CORIOLIS_AIO.Encounter.PartyXP"}}</label>
          <input type="number" id="aio-party-xp" name="partyXP" value="0" min="0" max="200" />
        </div>
      </div>
      <p class="hint">{{localize "CORIOLIS_AIO.Encounter.PartyXPHint"}}</p>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-gem"></i> Rewards</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="generateLoot" checked />
          {{localize "CORIOLIS_AIO.Encounter.GenerateLoot"}}
        </label>
      </div>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="generateEnemyShip" />
          {{localize "CORIOLIS_AIO.Encounter.GenerateEnemyShip"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.Encounter.GenerateEnemyShipHint"}}</p>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       SHIP PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'ship')}}hidden{{/unless}}" data-panel="ship">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-rocket"></i> Ship</legend>

      <div class="form-group">
        <label for="aio-ship-class">{{localize "CORIOLIS_AIO.Ship.Class"}}</label>
        <select id="aio-ship-class" name="classKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each shipClasses}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
        <p class="hint" id="aio-ship-class-desc"></p>
      </div>

      <div class="form-group">
        <label for="aio-ship-name">{{localize "CORIOLIS_AIO.Ship.Name"}}</label>
        <input type="text" id="aio-ship-name" name="shipName" placeholder="{{localize "CORIOLIS_AIO.Ship.NamePlaceholder"}}" />
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-cog"></i> Options</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="includeProblem" checked />
          {{localize "CORIOLIS_AIO.Ship.IncludeProblem"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.Ship.IncludeProblemHint"}}</p>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       SHIP ENCOUNTER PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'shipEncounter')}}hidden{{/unless}}" data-panel="shipEncounter">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-crosshairs"></i> {{localize "CORIOLIS_AIO.ShipEncounter.Title"}}</legend>

      <div class="form-group">
        <label for="aio-ship-encounter-template">{{localize "CORIOLIS_AIO.ShipEncounter.Template"}}</label>
        <select id="aio-ship-encounter-template" name="shipEncounterTemplate">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each shipEncounterTemplates}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
        <p class="hint" id="aio-ship-encounter-desc"></p>
      </div>

      <div class="form-group">
        <label for="aio-ship-encounter-difficulty">{{localize "CORIOLIS_AIO.ShipEncounter.Difficulty"}}</label>
        <select id="aio-ship-encounter-difficulty" name="shipEncounterDifficulty">
          {{#each difficulties}}
          <option value="{{@key}}" {{#if this.default}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-users"></i> Party</legend>

      <div class="form-row">
        <div class="form-group">
          <label for="aio-ship-encounter-party-size">{{localize "CORIOLIS_AIO.Encounter.PartySize"}}</label>
          <input type="number" id="aio-ship-encounter-party-size" name="shipEncounterPartySize" value="4" min="1" max="10" />
        </div>

        <div class="form-group">
          <label for="aio-ship-encounter-party-xp">{{localize "CORIOLIS_AIO.Encounter.PartyXP"}}</label>
          <input type="number" id="aio-ship-encounter-party-xp" name="shipEncounterPartyXP" value="0" min="0" max="200" />
        </div>
      </div>
      <p class="hint">{{localize "CORIOLIS_AIO.Encounter.PartyXPHint"}}</p>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-gem"></i> {{localize "CORIOLIS_AIO.ShipEncounter.Salvage"}}</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="generateSalvage" checked />
          {{localize "CORIOLIS_AIO.ShipEncounter.GenerateSalvage"}}
        </label>
      </div>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="generateBoardingParty" />
          {{localize "CORIOLIS_AIO.ShipEncounter.GenerateBoarding"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.ShipEncounter.GenerateBoardingHint"}}</p>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       PARTY PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'party')}}hidden{{/unless}}" data-panel="party">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-users"></i> {{localize "CORIOLIS_AIO.Party.Title"}}</legend>

      <div class="form-group">
        <label for="aio-party-gen-size">{{localize "CORIOLIS_AIO.Party.Size"}}</label>
        <input type="number" id="aio-party-gen-size" name="partyGenSize" value="4" min="3" max="6" />
      </div>

      <div class="form-group">
        <label for="aio-party-group-concept">{{localize "CORIOLIS_AIO.Dialog.GroupConcept"}}</label>
        <select id="aio-party-group-concept" name="partyGroupConceptKey">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each groupConcepts}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-cog"></i> Options</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="allowDuplicates" />
          {{localize "CORIOLIS_AIO.Party.AllowDuplicates"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.Party.AllowDuplicatesHint"}}</p>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       NPC PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'npc')}}hidden{{/unless}}" data-panel="npc">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-user-secret"></i> {{localize "CORIOLIS_AIO.NPC.Title"}}</legend>

      <div class="form-group">
        <label for="aio-npc-archetype">{{localize "CORIOLIS_AIO.NPC.Archetype"}}</label>
        <select id="aio-npc-archetype" name="npcArchetype">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each npcArchetypes}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="aio-npc-faction">{{localize "CORIOLIS_AIO.NPC.Faction"}}</label>
        <select id="aio-npc-faction" name="npcFaction">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each npcFactions}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>

      <div class="form-group">
        <label for="aio-npc-name">{{localize "CORIOLIS_AIO.Dialog.Name"}}</label>
        <input type="text" id="aio-npc-name" name="npcName" placeholder="{{localize "CORIOLIS_AIO.Dialog.NamePlaceholder"}}" />
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-star-and-crescent"></i> {{localize "CORIOLIS_AIO.NPC.MysticPowersSection"}}</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="npcMysticPowers" checked />
          {{localize "CORIOLIS_AIO.NPC.MysticPowers"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.NPC.MysticPowersHint"}}</p>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-cog"></i> Output</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="npcCreateActor" />
          {{localize "CORIOLIS_AIO.NPC.CreateActor"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.NPC.CreateActorHint"}}</p>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       MISSION PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'mission')}}hidden{{/unless}}" data-panel="mission">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-scroll"></i> {{localize "CORIOLIS_AIO.Mission.Title"}}</legend>

      <div class="form-group">
        <label for="aio-mission-template">{{localize "CORIOLIS_AIO.Mission.Template"}}</label>
        <select id="aio-mission-template" name="missionTemplate">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each missionTemplates}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
        <p class="hint" id="aio-mission-desc"></p>
      </div>

      <div class="form-group">
        <label for="aio-mission-faction">{{localize "CORIOLIS_AIO.Mission.PatronFaction"}}</label>
        <select id="aio-mission-faction" name="missionFaction">
          <option value="">{{localize "CORIOLIS_AIO.Dialog.Random"}}</option>
          {{#each npcFactions}}
          <option value="{{@key}}">{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-users"></i> {{localize "CORIOLIS_AIO.Mission.NPCs"}}</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="missionGeneratePatron" checked />
          {{localize "CORIOLIS_AIO.Mission.GeneratePatron"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.Mission.GeneratePatronHint"}}</p>
      </div>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="missionGenerateAntagonist" checked />
          {{localize "CORIOLIS_AIO.Mission.GenerateAntagonist"}}
        </label>
        <p class="hint">{{localize "CORIOLIS_AIO.Mission.GenerateAntagonistHint"}}</p>
      </div>
    </fieldset>

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-crosshairs"></i> {{localize "CORIOLIS_AIO.Mission.Encounters"}}</legend>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="missionGenerateEncounter" />
          {{localize "CORIOLIS_AIO.Mission.GenerateEncounter"}}
        </label>
      </div>

      <div class="form-group">
        <label class="coriolis-checkbox">
          <input type="checkbox" name="missionGenerateShipEncounter" />
          {{localize "CORIOLIS_AIO.Mission.GenerateShipEncounter"}}
        </label>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="aio-mission-party-size">{{localize "CORIOLIS_AIO.Encounter.PartySize"}}</label>
          <input type="number" id="aio-mission-party-size" name="missionPartySize" value="4" min="1" max="10" />
        </div>

        <div class="form-group">
          <label for="aio-mission-party-xp">{{localize "CORIOLIS_AIO.Encounter.PartyXP"}}</label>
          <input type="number" id="aio-mission-party-xp" name="missionPartyXP" value="0" min="0" max="200" />
        </div>
      </div>

      <div class="form-group">
        <label for="aio-mission-difficulty">{{localize "CORIOLIS_AIO.Mission.Difficulty"}}</label>
        <select id="aio-mission-difficulty" name="missionDifficulty">
          {{#each difficulties}}
          <option value="{{@key}}" {{#if this.default}}selected{{/if}}>{{this.label}}</option>
          {{/each}}
        </select>
      </div>
    </fieldset>
  </div>

  {{!-- ═══════════════════════════════════════════════
       AI NPC PANEL
       ═══════════════════════════════════════════════ --}}
  <div class="coriolis-gen-panel {{#unless (eq initialTab 'aiNpc')}}hidden{{/unless}}" data-panel="aiNpc">

    <fieldset class="coriolis-section">
      <legend><i class="fas fa-brain"></i> {{localize "CORIOLIS_AIO.AINPC.Title"}}</legend>

      <div class="form-group">
        <label for="aio-ai-prompt">{{localize "CORIOLIS_AIO.AINPC.Prompt"}}</label>
        <textarea id="aio-ai-prompt" name="aiNpcPrompt" rows="5" placeholder="{{localize "CORIOLIS_AIO.AINPC.PromptPlaceholder"}}"></textarea>
        <p class="hint">{{localize "CORIOLIS_AIO.AINPC.PromptHint"}}</p>
      </div>
    </fieldset>
  </div>
</form>
